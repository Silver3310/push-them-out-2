{
    "version": "1.1.0",
    "_comment": "Audio manifest. Customise the soundtrack and SFX without touching code: change a `src` to repoint a sound, change `musicByLevel` / `menuMusic` to repoint a track. Missing files are non-fatal (the AudioManager logs a warning and the game keeps running). preload:false defers loading until first use; music tracks are typically lazy-loaded so menus aren't blocked by long files.",

    "_schema": {
        "version":           "Manifest format version. Bump on incompatible changes.",
        "menuMusic":         "Sound key (must exist in `sounds`) played on the main menu.",
        "musicByLevel":      "Object mapping LevelConfig.LEVELS[i].id (as a string) to a sound key. Add a new entry to introduce music for a new level — no code change required.",
        "musicCrossfadeSec": "Seconds for the music crossfade between menu/level tracks. Aligned by default with LevelManager's TRANSITION_DURATION so the audio handover lands in lock-step with the visual cross-fade.",
        "musicPauseFadeSec": "Seconds for the gentle dip/restore of music when the player toggles pause.",
        "sounds":            "Map of sound key → entry. Each entry: { src, preload?, category, volume? }. category is 'sfx' or 'music'; volume (optional, 0-1) scales this clip on top of the global SFX/music bus volume."
    },

    "_groups": {
        "music":         ["music_menu", "music_level_1", "music_level_2", "music_level_3", "music_level_4", "music_level_5", "music_level_6"],
        "sfx_menu":      ["menu_hover", "menu_click", "pause_click", "notification", "warning"],
        "sfx_combat":    ["player_shoot", "enemy_shoot", "player_death", "black_hole_death", "boss_ray"],
        "sfx_pickups":   ["star_collected", "cake_eaten"],
        "sfx_legacy":    ["ball_hit", "ball_in_hole", "shoot", "special", "respawn", "victory"]
    },

    "menuMusic": "music_menu",
    "musicByLevel": {
        "1": "music_level_1",
        "2": "music_level_2",
        "3": "music_level_3",
        "4": "music_level_4",
        "5": "music_level_5",
        "6": "music_level_6"
    },
    "musicCrossfadeSec": 2.5,
    "musicPauseFadeSec": 0.25,

    "sounds": {
        "music_menu":          { "src": "assets/sounds/music/menu.ogg",            "preload": false, "category": "music" },
        "music_level_1":       { "src": "assets/sounds/music/level_1.ogg",         "preload": false, "category": "music" },
        "music_level_2":       { "src": "assets/sounds/music/level_2.ogg",         "preload": false, "category": "music" },
        "music_level_3":       { "src": "assets/sounds/music/level_3.ogg",         "preload": false, "category": "music" },
        "music_level_4":       { "src": "assets/sounds/music/level_4.ogg",         "preload": false, "category": "music" },
        "music_level_5":       { "src": "assets/sounds/music/level_5.ogg",         "preload": false, "category": "music" },
        "music_level_6":       { "src": "assets/sounds/music/level_6.ogg",         "preload": false, "category": "music" },

        "menu_hover":          { "src": "assets/sounds/sfx/menu_hover.ogg",        "preload": true,  "category": "sfx", "volume": 0.6 },
        "menu_click":          { "src": "assets/sounds/sfx/menu_click.ogg",        "preload": true,  "category": "sfx" },
        "pause_click":         { "src": "assets/sounds/sfx/pause_click.ogg",       "preload": true,  "category": "sfx" },
        "notification":        { "src": "assets/sounds/sfx/notification.ogg",      "preload": true,  "category": "sfx", "volume": 0.7 },
        "warning":             { "src": "assets/sounds/sfx/warning.ogg",           "preload": true,  "category": "sfx" },

        "player_shoot":        { "src": "assets/sounds/sfx/shoot.ogg",             "preload": true,  "category": "sfx" },
        "enemy_shoot":         { "src": "assets/sounds/sfx/enemy_shoot.ogg",       "preload": true,  "category": "sfx" },
        "player_death":        { "src": "assets/sounds/sfx/player_death.ogg",      "preload": true,  "category": "sfx" },
        "black_hole_death":    { "src": "assets/sounds/sfx/black_hole_death.ogg",  "preload": true,  "category": "sfx" },
        "boss_ray":            { "src": "assets/sounds/sfx/boss_ray.ogg",          "preload": true,  "category": "sfx" },

        "star_collected":      { "src": "assets/sounds/sfx/star_collected.ogg",    "preload": true,  "category": "sfx", "volume": 0.7 },
        "cake_eaten":          { "src": "assets/sounds/sfx/cake_eaten.ogg",        "preload": true,  "category": "sfx" },

        "ball_hit":            { "src": "assets/sounds/sfx/ball_hit.ogg",          "preload": true,  "category": "sfx" },
        "ball_in_hole":        { "src": "assets/sounds/sfx/ball_in_hole.ogg",      "preload": true,  "category": "sfx" },
        "shoot":               { "src": "assets/sounds/sfx/shoot.ogg",             "preload": true,  "category": "sfx" },
        "special":             { "src": "assets/sounds/sfx/special.ogg",           "preload": true,  "category": "sfx" },
        "respawn":             { "src": "assets/sounds/sfx/respawn.ogg",           "preload": true,  "category": "sfx" },
        "victory":             { "src": "assets/sounds/sfx/victory.ogg",           "preload": false, "category": "sfx" }
    }
}
