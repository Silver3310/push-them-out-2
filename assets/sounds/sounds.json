{
    "version": "1.1.0",
    "_comment": "Audio manifest. Customise the soundtrack and SFX without touching code: change a `src` to repoint a sound, change `musicByLevel` / `menuMusic` to repoint a track. Missing files are non-fatal (the AudioManager logs a warning and the game keeps running). preload:false defers loading until first use; music tracks are typically lazy-loaded so menus aren't blocked by long files.",

    "_schema": {
        "version":           "Manifest format version. Bump on incompatible changes.",
        "menuMusic":         "Sound key (must exist in `sounds`) played on the main menu.",
        "musicByLevel":      "Object mapping LevelConfig.LEVELS[i].id (as a string) to a sound key. Add a new entry to introduce music for a new level — no code change required.",
        "musicCrossfadeSec": "Seconds for the music crossfade between menu/level tracks. Aligned by default with LevelManager's TRANSITION_DURATION so the audio handover lands in lock-step with the visual cross-fade.",
        "musicPauseFadeSec": "Seconds for the gentle dip/restore of music when the player toggles pause.",
        "sounds":            "Map of sound key → entry. Each entry: { src, preload?, category, volume? }. category is 'sfx' or 'music'; volume (optional, 0-1) scales this clip on top of the global SFX/music bus volume."
    },

    "_groups": {
        "music":         ["music_menu", "music_level_1", "music_level_2", "music_level_3", "music_level_4", "music_level_5", "music_level_6"],
        "sfx_menu":      ["menu_hover", "menu_click", "pause_click", "notification", "warning"],
        "sfx_combat":    ["player_shoot", "enemy_shoot", "player_death", "black_hole_death", "boss_ray"],
        "sfx_pickups":   ["star_collected", "cake_eaten"],
        "sfx_legacy":    ["ball_hit", "ball_in_hole", "shoot", "special", "respawn", "victory"]
    },

    "menuMusic":  "music_menu",
    "introMusic": "music_intro",
    "outroMusic": "music_outro",
    "musicByLevel": {
        "1": "music_level_1",
        "2": "music_level_2",
        "3": "music_level_3",
        "4": "music_level_4",
        "5": "music_level_5",
        "6": "music_level_6"
    },
    "musicCrossfadeSec": 2.5,
    "musicPauseFadeSec": 0.25,

    "sounds": {
        "music_menu":          { "src": "assets/sounds/music/Menu_Sound.wav",            "preload": false, "category": "music" },
        "music_intro":         { "src": "assets/sounds/music/Intro_Sound.wav",           "preload": false, "category": "music" },
        "music_outro":         { "src": "assets/sounds/music/Outro_Sound.wav",           "preload": false, "category": "music" },
        "music_level_1":       { "src": "assets/sounds/music/1_Level_Sound_01.wav",         "preload": false, "category": "music" },
        "music_level_2":       { "src": "assets/sounds/music/2_Level_Sound_02.wav",         "preload": false, "category": "music" },
        "music_level_3":       { "src": "assets/sounds/music/3_Level_Sound_03.wav",         "preload": false, "category": "music" },
        "music_level_4":       { "src": "assets/sounds/music/4_Level_Sound_04.wav",         "preload": false, "category": "music" },
        "music_level_5":       { "src": "assets/sounds/music/5_Level_Sound_05.wav",         "preload": false, "category": "music" },
        "music_level_6":       { "src": "assets/sounds/music/6_Level_Sound_06.wav",         "preload": false, "category": "music" },

        "menu_hover":          { "src": "assets/sounds/sfx/Hover_Button_04.wav",        "preload": true,  "category": "sfx", "volume": 0.5 },
        "menu_click":          { "src": "assets/sounds/sfx/Standard_Button_01.wav",        "preload": true,  "category": "sfx", "volume": 0.5 },
        "pause_click":         { "src": "assets/sounds/sfx/Pause_01.wav",       "preload": true,  "category": "sfx", "volume": 0.5 },
        "notification":        { "src": "assets/sounds/sfx/Notification_01.wav",      "preload": true,  "category": "sfx", "volume": 0.5 },
        "warning":             { "src": "assets/sounds/sfx/Warning_01.wav",           "preload": true,  "category": "sfx", "volume": 0.5 },

        "player_shoot":        { "src": "assets/sounds/sfx/Shoot_01.wav",             "preload": true,  "category": "sfx", "volume": 0.5 },
        "enemy_shoot":         { "src": "assets/sounds/sfx/Shoot_01.wav",       "preload": true,  "category": "sfx", "volume": 0.5 },
        "player_death":        { "src": "assets/sounds/sfx/Death_01.wav",      "preload": true,  "category": "sfx", "volume": 0.5 },
        "black_hole_death":    { "src": "assets/sounds/sfx/Death_From_Black_Hole_01.wav",  "preload": true,  "category": "sfx", "volume": 0.5 },
        "boss_ray":            { "src": "assets/sounds/sfx/Boss_Ray_01.wav",          "preload": true,  "category": "sfx", "volume": 2 },

        "star_collected":      { "src": "assets/sounds/sfx/Collect_Star_01.wav",    "preload": true,  "category": "sfx", "volume": 0.5 },
        "cake_eaten":          { "src": "assets/sounds/sfx/Gulp_01.wav",        "preload": true,  "category": "sfx", "volume": 0.5 },

        "ball_hit":            { "src": "assets/sounds/sfx/ball_hit.ogg",          "preload": true,  "category": "sfx", "volume": 0.5 },
        "ball_in_hole":        { "src": "assets/sounds/sfx/ball_in_hole.ogg",      "preload": true,  "category": "sfx", "volume": 0.5 },
        "shoot":               { "src": "assets/sounds/sfx/Shoot_01.wav",             "preload": true,  "category": "sfx", "volume": 0.5 },
        "special":             { "src": "assets/sounds/sfx/special.ogg",           "preload": true,  "category": "sfx", "volume": 0.5 },
        "respawn":             { "src": "assets/sounds/sfx/Revive_01.wav",           "preload": true,  "category": "sfx", "volume": 0.5 },
        "victory":             { "src": "assets/sounds/sfx/victory.ogg",           "preload": false, "category": "sfx", "volume": 0.5 }
    }
}
